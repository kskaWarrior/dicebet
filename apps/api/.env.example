# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
# (user tokens are verified via the project's public JWKS endpoint — no JWT secret needed)

# Stripe (test mode keys only!)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Comma-separated allowed origins: web app + Capacitor shells
CORS_ORIGINS=http://localhost:3000,capacitor://localhost,http://localhost

# Where Stripe Checkout sends the user back to
CHECKOUT_RETURN_URL=http://localhost:3000

PORT=8080
